---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
const [models, orgs] = await Promise.all([getCollection('models'), getCollection('organizations')]);
const orgName = (id: string) => orgs.find((o) => o.id === id)?.data.name_ko ?? id;
const cmp = models
  .map((m) => ({
    id: m.id, name: m.data.name, org: orgName(m.data.organization_id),
    release: m.data.release_date ?? '', pv: m.data.parameter_count?.value ?? null,
    pd: m.data.parameter_count?.disclosure ?? 'undisclosed',
    ctx: m.data.context_length?.value ?? null,
    modalities: (m.data.modalities ?? []).join(', '), languages: (m.data.languages ?? []).join(', '),
    api: !!m.data.availability?.api, weights: !!m.data.availability?.weights,
    onprem: !!m.data.deployment?.on_premise,
    license: m.data.license?.name ?? '', commercial: m.data.license?.commercial_use ?? 'unknown',
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
const base = import.meta.env.BASE_URL;
---
<Base title="AI 모델 비교 — 한국 LLM 스펙 나란히 비교 | Korea AI Map"
  description="한국 AI 모델을 최대 4개까지 선택해 파라미터 수, 컨텍스트 길이, 라이선스, 상업 이용 가능 여부, 공개 범위를 나란히 비교합니다. 선택 상태는 URL로 공유되어 팀과 손쉽게 검토할 수 있습니다.">
  <h1>모델 비교</h1>
  <p class="lead">최대 4개 모델을 선택해 나란히 비교합니다. 선택 상태는 URL로 공유됩니다.</p>

  <input id="f-q" type="search" placeholder="모델 검색…" autocomplete="off" />
  <div id="picker" class="picker"></div>
  <p id="hint" class="muted"></p>
  <div id="table" class="table-wrap"></div>

  <script type="application/json" id="data" set:html={JSON.stringify(cmp)}></script>
  <script define:vars={{ base }}>
    const DATA = JSON.parse(document.getElementById('data').textContent);
    const byId = Object.fromEntries(DATA.map((m) => [m.id, m]));
    const MAX = 4;
    const picker = document.getElementById('picker');
    const table = document.getElementById('table');
    const hint = document.getElementById('hint');
    const fq = document.getElementById('f-q');
    const mkUrl = (id) => (base + '/models/' + id + '/').replace(/\/{2,}/g, '/');
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    let selected = (new URL(location.href).searchParams.get('ids') || '').split(',').filter((x) => byId[x]).slice(0, MAX);

    function paramText(v, d) {
      if (v == null) return '미공개';
      const b = v / 1e9;
      const n = b >= 1 ? (Number.isInteger(b) ? b : b.toFixed(1)) + 'B' : (v / 1e6).toFixed(0) + 'M';
      return d && d !== 'confident' ? n + ' (추정)' : n;
    }
    const yn = (b) => (b ? '<span class="yes">✓</span>' : '<span class="no">–</span>');
    const na = (s) => `<span class="na">${s}</span>`;
    const commercialLabel = { allowed: '가능', restricted: '제한적', prohibited: '불가', unknown: '미상' };

    function renderPicker() {
      const q = fq.value.trim().toLowerCase();
      picker.innerHTML = DATA
        .filter((m) => !q || (m.name + ' ' + m.org).toLowerCase().includes(q))
        .map((m) => {
          const on = selected.includes(m.id);
          const dis = !on && selected.length >= MAX;
          return `<label class="pick ${on ? 'on' : ''}"><input type="checkbox" value="${m.id}" ${on ? 'checked' : ''} ${dis ? 'disabled' : ''}> ${esc(m.name)} <span class="muted">· ${esc(m.org)}</span></label>`;
        }).join('');
      picker.querySelectorAll('input').forEach((el) =>
        el.addEventListener('change', () => toggle(el.value, el.checked)));
      hint.textContent = `${selected.length} / ${MAX} 선택됨`;
    }

    function toggle(id, on) {
      if (on) { if (selected.length < MAX && !selected.includes(id)) selected.push(id); }
      else selected = selected.filter((x) => x !== id);
      sync(); renderPicker(); renderTable();
    }

    function row(label, fn) {
      return `<tr><th scope="row">${label}</th>` + selected.map((id) => `<td>${fn(byId[id])}</td>`).join('') + '</tr>';
    }
    function renderTable() {
      if (selected.length === 0) { table.innerHTML = '<p class="muted">위에서 모델을 선택하세요.</p>'; return; }
      table.innerHTML = `<table class="cmp"><thead><tr><th></th>` +
        selected.map((id) => `<th><a href="${mkUrl(id)}">${esc(byId[id].name)}</a></th>`).join('') +
        `</tr></thead><tbody>` +
        row('개발 조직', (m) => esc(m.org) || na('—')) +
        row('출시일', (m) => (m.release ? esc(m.release) : na('—'))) +
        row('파라미터 수', (m) => (m.pv == null ? na('미공개') : paramText(m.pv, m.pd))) +
        row('컨텍스트', (m) => (m.ctx != null ? m.ctx.toLocaleString() : na('미공개'))) +
        row('모달리티', (m) => esc(m.modalities) || na('—')) +
        row('지원 언어', (m) => esc(m.languages) || na('—')) +
        row('API', (m) => yn(m.api)) +
        row('가중치 공개', (m) => yn(m.weights)) +
        row('온프레미스', (m) => yn(m.onprem)) +
        row('라이선스', (m) => esc(m.license) || na('—')) +
        row('상업 이용', (m) => commercialLabel[m.commercial] || m.commercial) +
        `</tbody></table>`;
    }
    function sync() {
      const u = new URL(location.href);
      if (selected.length) u.searchParams.set('ids', selected.join(',')); else u.searchParams.delete('ids');
      history.replaceState(null, '', u);
    }
    fq.addEventListener('input', renderPicker);
    renderPicker(); renderTable();
  </script>

  <style>
    #f-q { width: 100%; padding: 0.6rem 0.8rem; border: 1px solid var(--line); border-radius: var(--radius);
           background: var(--card); color: var(--fg); font-size: 1rem; margin-bottom: 0.8rem; }
    .picker { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr)); gap: 0.3rem;
              max-height: 240px; overflow-y: auto; border: 1px solid var(--line); border-radius: var(--radius); padding: 0.6rem; }
    .pick { display: block; font-size: 0.9rem; padding: 0.2rem 0.3rem; border-radius: 4px; cursor: pointer; }
    .pick.on { background: color-mix(in srgb, var(--link) 12%, transparent); }
    .pick input[disabled] + * { opacity: 0.4; }
    .table-wrap { overflow-x: auto; max-width: 100%; margin-top: 1.3rem;
      border: 1px solid var(--line); border-radius: 10px; }
  </style>

  <!-- 표는 JS(innerHTML)로 런타임 생성되므로 스코프 스타일이 안 먹는다 → 전역 스타일로 지정 -->
  <style is:global>
    table.cmp { border-collapse: collapse; width: max-content; min-width: 100%; font-size: 0.9rem; }
    table.cmp th, table.cmp td { padding: 0.65rem 1rem; text-align: left; vertical-align: top;
      white-space: nowrap; border-bottom: 1px solid var(--line); }
    table.cmp tbody tr:last-child th, table.cmp tbody tr:last-child td { border-bottom: 0; }
    /* 헤더 행: 모델명 강조 + 상단 고정 */
    table.cmp thead th { position: sticky; top: 0; background: var(--bg);
      border-bottom: 2px solid var(--fg); font-size: 0.95rem; padding-top: 0.85rem; padding-bottom: 0.85rem; z-index: 2; }
    table.cmp thead th a { color: var(--link); font-weight: 700; }
    /* 첫 열(항목 라벨): 좌측 고정 + 옅은 배경으로 구분 */
    table.cmp th[scope="row"] { position: sticky; left: 0; background: var(--card);
      color: var(--muted); font-weight: 500; border-right: 1px solid var(--line); z-index: 1; }
    table.cmp thead th:first-child { background: var(--card); left: 0; z-index: 3; border-right: 1px solid var(--line); }
    /* 행 hover 강조 */
    table.cmp tbody tr:hover td { background: color-mix(in srgb, var(--link) 6%, transparent); }
    /* 불리언·미공개 표기 */
    table.cmp .yes { color: var(--ok); font-weight: 700; }
    table.cmp .no { color: var(--dim); }
    table.cmp .na { color: var(--muted); font-style: italic; }
  </style>
</Base>
