---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { url } from '../../lib/url';
const items = (await getCollection('datasets')).sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<Base title="한국어 AI 데이터셋 — 말뭉치·QA·음성 | Korea AI Map"
  description="KorQuAD, 모두의 말뭉치, AI-Hub, KoAlpaca 등 한국어 AI 학습·평가에 쓰이는 데이터셋을 분야·언어·라이선스·공식 출처와 함께 정리했습니다. 한국어 자연어처리 연구에 필요한 데이터를 한눈에 확인할 수 있습니다.">
  <h1>데이터셋 <span class="count">{items.length}</span></h1>
  <p class="lead">한국어 AI 학습·평가 데이터.</p>
  <div class="grid">
    {items.map((x) => (
      <a class="card" href={url(`/datasets/${x.id}/`)}>
        <h3>{x.data.name}</h3>
        <div class="sub">{x.data.category}</div>
        <div><StatusBadge status={x.data.verification_status} /></div>
        {x.data.description_ko && <p class="desc">{x.data.description_ko.slice(0, 80)}…</p>}
      </a>
    ))}
  </div>
</Base>
