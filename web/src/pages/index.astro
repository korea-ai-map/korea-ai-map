---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { url } from '../lib/url';
import { buildSearchIndex } from '../lib/data';

const [organizations, models, products, openSource, datasets, benchmarks, papers] = await Promise.all([
  getCollection('organizations'), getCollection('models'), getCollection('products'),
  getCollection('open-source'), getCollection('datasets'), getCollection('benchmarks'), getCollection('papers'),
]);

const cards = [
  { label: '조직', slug: 'organizations', count: organizations.length, desc: '기업·연구조직·스타트업' },
  { label: '모델', slug: 'models', count: models.length, desc: 'LLM·비전·멀티모달' },
  { label: '제품/서비스', slug: 'products', count: products.length, desc: 'AI 제품·칩·인프라' },
  { label: '데이터셋', slug: 'datasets', count: datasets.length, desc: '한국어 학습 데이터' },
  { label: '벤치마크', slug: 'benchmarks', count: benchmarks.length, desc: '한국어 평가' },
  { label: '오픈소스', slug: 'open-source', count: openSource.length, desc: 'GitHub·Hugging Face' },
  { label: '논문', slug: 'papers', count: papers.length, desc: '기술보고서·연구 논문' },
];
const total = cards.reduce((s, c) => s + c.count, 0);

const index = await buildSearchIndex();
const base = import.meta.env.BASE_URL;

// 최근 업데이트 = 빌드(배포) 시각. KST 로 표기.
const buildDate = new Date();
const updatedKST = new Intl.DateTimeFormat('ko-KR', {
  timeZone: 'Asia/Seoul',
  year: 'numeric', month: '2-digit', day: '2-digit',
  hour: '2-digit', minute: '2-digit', hour12: false,
}).format(buildDate);
---
<Base title="Korea AI Map — 한국 AI 모델·기업·데이터셋 오픈 데이터베이스">
  <h1>Korea AI Map</h1>
  <p class="lead">한국에서 실제로 개발·운영되는 AI 기술과 조직을 검증 가능한 근거로 연결한 오픈 데이터베이스입니다. 현재 <strong>{total}</strong>개 항목.</p>

  <input id="home-q" type="search" placeholder="조직·모델·제품·데이터셋·벤치마크·오픈소스·논문 검색…" autocomplete="off" aria-label="통합 검색" />
  <p id="home-summary" class="muted" aria-live="polite"></p>
  <div id="home-results"></div>

  <div id="home-default">
    <div class="grid">
      {cards.map((c) => (
        <a class="card" href={url(`/${c.slug}/`)}>
          <h3>{c.label} <span class="count">{c.count}</span></h3>
          <p class="desc muted">{c.desc}</p>
        </a>
      ))}
    </div>

    <h2>이 프로젝트에 대하여</h2>
    <p>모든 항목에는 <strong>출처</strong>와 <strong>검증 상태</strong>, <strong>최종 검증일</strong>이 부착됩니다. 확인되지 않은 수치(파라미터 수 등)는 추정하지 않고 <em>미공개</em>로 표기합니다. 데이터는 <a href="https://github.com/korea-ai-map/korea-ai-map">GitHub</a>에서 관리되며 누구나 제보·수정을 제안할 수 있습니다.</p>

    <p class="updated">최근 업데이트: <time datetime={buildDate.toISOString()}>{updatedKST}</time> (KST)</p>
  </div>

  <script type="application/json" id="idx" set:html={JSON.stringify(index)}></script>
  <script define:vars={{ base }}>
    const idx = JSON.parse(document.getElementById('idx').textContent);
    const q = document.getElementById('home-q');
    const results = document.getElementById('home-results');
    const summary = document.getElementById('home-summary');
    const def = document.getElementById('home-default');
    const order = ['organizations', 'models', 'products', 'datasets', 'benchmarks', 'open-source', 'papers'];
    const mkUrl = (t, id) => (base + '/' + t + '/' + id + '/').replace(/\/{2,}/g, '/');
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    function render(term) {
      term = term.trim().toLowerCase();
      if (!term) { results.innerHTML = ''; summary.textContent = ''; def.hidden = false; return; }
      def.hidden = true;
      const matches = idx.filter((e) =>
        (e.name + ' ' + e.name_en + ' ' + e.desc + ' ' + e.tags.join(' ')).toLowerCase().includes(term));
      if (matches.length === 0) {
        summary.textContent = `"${term}" 검색 결과 없음`;
        results.innerHTML = `<p>찾는 항목이 없다면 <a href="https://github.com/korea-ai-map/korea-ai-map/issues/new/choose">신규 등재를 제보</a>해 주세요.</p>`;
        return;
      }
      summary.textContent = `${matches.length}건`;
      const groups = {};
      for (const m of matches) (groups[m.type] ??= []).push(m);
      let html = '';
      for (const t of order) {
        const g = groups[t];
        if (!g) continue;
        html += `<h2>${g[0].typeLabel} <span class="count">${g.length}</span></h2><div class="grid">`;
        for (const e of g) {
          const sub = e.name_en && e.name_en !== e.name ? esc(e.name_en) : '';
          html += `<a class="card" href="${mkUrl(e.type, e.id)}"><h3>${esc(e.name)}</h3>` +
            (sub ? `<div class="sub">${sub}</div>` : '') +
            (e.desc ? `<p class="desc">${esc(e.desc.slice(0, 80))}${e.desc.length > 80 ? '…' : ''}</p>` : '') +
            `</a>`;
        }
        html += '</div>';
      }
      results.innerHTML = html;
    }

    function sync() {
      const u = new URL(location.href);
      if (q.value.trim()) u.searchParams.set('q', q.value.trim()); else u.searchParams.delete('q');
      history.replaceState(null, '', u);
    }
    q.addEventListener('input', () => { render(q.value); sync(); });

    const initial = new URL(location.href).searchParams.get('q');
    if (initial) { q.value = initial; render(initial); }
  </script>

  <style>
    #home-q { width: 100%; font-size: 1.05rem; padding: 0.7rem 0.9rem; margin: 0.4rem 0 0;
      border: 1px solid var(--line); border-radius: var(--radius); background: var(--card); color: var(--fg); }
    #home-q:focus { outline: 2px solid var(--link); outline-offset: 1px; }
    #home-summary { margin: 0.5rem 0 0; }
    .updated { margin-top: 2rem; color: var(--muted); font-size: 0.85rem; text-align: right; }
  </style>
</Base>
