---
import Base from '../layouts/Base.astro';
import { buildSearchIndex } from '../lib/data';
const index = await buildSearchIndex();
const base = import.meta.env.BASE_URL;
---
<Base title="통합 검색 — 한국 AI 조직·모델·데이터 | Korea AI Map"
  description="한국 AI 조직, 모델, 제품, 데이터셋, 벤치마크, 오픈소스를 이름·설명·태그로 한 번에 검색합니다. 한글과 영문 부분 일치를 지원하며 결과를 유형별로 묶어 보여주고 URL로 공유할 수 있습니다.">
  <h1>통합 검색</h1>
  <p class="lead">조직·모델·제품·데이터셋·벤치마크·오픈소스를 한 번에 검색합니다. 한글/영문 이름·설명·태그를 부분 일치로 찾습니다.</p>

  <input id="q" type="search" placeholder="예: 카카오, LLM, hyperclova, 벤치마크…" autocomplete="off" autofocus />
  <p id="summary" class="muted" aria-live="polite"></p>
  <div id="results"></div>

  <script type="application/json" id="idx" set:html={JSON.stringify(index)}></script>
  <script define:vars={{ base }}>
    const idx = JSON.parse(document.getElementById('idx').textContent);
    const q = document.getElementById('q');
    const results = document.getElementById('results');
    const summary = document.getElementById('summary');
    const order = ['organizations', 'models', 'products', 'datasets', 'benchmarks', 'open-source'];
    const mkUrl = (t, id) => (base + '/' + t + '/' + id + '/').replace(/\/{2,}/g, '/');
    const esc = (s) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    function search(term) {
      term = term.trim().toLowerCase();
      if (!term) return null;
      return idx.filter((e) => {
        const hay = (e.name + ' ' + e.name_en + ' ' + e.desc + ' ' + e.tags.join(' ')).toLowerCase();
        return hay.includes(term);
      });
    }

    function render(term) {
      const matches = search(term);
      if (matches === null) { results.innerHTML = ''; summary.textContent = ''; return; }
      if (matches.length === 0) {
        summary.textContent = `"${term}" 검색 결과 없음`;
        results.innerHTML = `<p>찾는 항목이 없다면 <a href="https://github.com/korea-ai-map/korea-ai-map/issues/new/choose">신규 등재를 제보</a>해 주세요.</p>`;
        return;
      }
      summary.textContent = `${matches.length}건`;
      const groups = {};
      for (const m of matches) (groups[m.type] ??= []).push(m);
      let html = '';
      for (const t of order) {
        const g = groups[t];
        if (!g) continue;
        html += `<h2>${g[0].typeLabel} <span class="count">${g.length}</span></h2><div class="grid">`;
        for (const e of g) {
          const sub = e.name_en && e.name_en !== e.name ? esc(e.name_en) : '';
          html += `<a class="card" href="${mkUrl(e.type, e.id)}"><h3>${esc(e.name)}</h3>` +
            (sub ? `<div class="sub">${sub}</div>` : '') +
            (e.desc ? `<p class="desc">${esc(e.desc.slice(0, 80))}${e.desc.length > 80 ? '…' : ''}</p>` : '') +
            `</a>`;
        }
        html += '</div>';
      }
      results.innerHTML = html;
    }

    function sync() {
      const u = new URL(location.href);
      if (q.value.trim()) u.searchParams.set('q', q.value.trim()); else u.searchParams.delete('q');
      history.replaceState(null, '', u);
    }
    q.addEventListener('input', () => { render(q.value); sync(); });

    const initial = new URL(location.href).searchParams.get('q');
    if (initial) { q.value = initial; render(initial); }
  </script>

  <style>
    #q { width: 100%; font-size: 1.05rem; padding: 0.7rem 0.9rem; border: 1px solid var(--line);
         border-radius: var(--radius); background: var(--card); color: var(--fg); }
    #q:focus { outline: 2px solid var(--link); outline-offset: 1px; }
    #summary { margin: 0.6rem 0 0; }
  </style>
</Base>
