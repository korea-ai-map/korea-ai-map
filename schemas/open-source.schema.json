{
  "$ref": "#/definitions/open-source",
  "definitions": {
    "open-source": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "organization_id": {
          "type": "string"
        },
        "repo_type": {
          "type": "string",
          "enum": [
            "github-repo",
            "huggingface-model",
            "framework",
            "eval-tool",
            "inference-tool",
            "agent-mcp"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "description_ko": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "stars": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "last_verified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "verified",
            "official-source",
            "community-reviewed",
            "submitted",
            "needs-review",
            "outdated",
            "disputed",
            "archived"
          ]
        }
      },
      "required": [
        "name",
        "repo_type",
        "url",
        "sources",
        "last_verified",
        "verification_status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}