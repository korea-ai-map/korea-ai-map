{
  "$ref": "#/definitions/models",
  "definitions": {
    "models": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "organization_id": {
          "type": "string"
        },
        "model_family": {
          "type": "string"
        },
        "release_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "announced",
            "deprecated",
            "archived"
          ]
        },
        "modalities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "parameter_count": {
          "type": "object",
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ]
            },
            "disclosure": {
              "type": "string",
              "enum": [
                "confident",
                "likely",
                "speculative",
                "undisclosed",
                "not-applicable"
              ]
            }
          },
          "required": [
            "value",
            "disclosure"
          ],
          "additionalProperties": false
        },
        "context_length": {
          "type": "object",
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ]
            },
            "confidence": {
              "type": "string",
              "enum": [
                "confident",
                "likely",
                "speculative",
                "undisclosed",
                "not-applicable"
              ]
            }
          },
          "required": [
            "value",
            "confidence"
          ],
          "additionalProperties": false
        },
        "availability": {
          "type": "object",
          "properties": {
            "api": {
              "type": "boolean"
            },
            "weights": {
              "type": "boolean"
            },
            "demo": {
              "type": "boolean"
            }
          },
          "required": [
            "api",
            "weights",
            "demo"
          ],
          "additionalProperties": false
        },
        "license": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "commercial_use": {
              "type": "string",
              "enum": [
                "allowed",
                "restricted",
                "prohibited",
                "unknown"
              ]
            }
          },
          "required": [
            "name",
            "commercial_use"
          ],
          "additionalProperties": false
        },
        "deployment": {
          "type": "object",
          "properties": {
            "cloud": {
              "type": "boolean"
            },
            "on_premise": {
              "type": "boolean"
            }
          },
          "required": [
            "cloud",
            "on_premise"
          ],
          "additionalProperties": false
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "base_model": {
          "type": "string"
        },
        "benchmark_results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "benchmark": {
                "type": "string"
              },
              "score": {
                "type": "number"
              },
              "metric": {
                "type": "string"
              },
              "source": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "benchmark",
              "score"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "links": {
          "type": "object",
          "properties": {
            "official": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uri"
                },
                {
                  "type": "null"
                }
              ]
            },
            "model_card": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uri"
                },
                {
                  "type": "null"
                }
              ]
            },
            "huggingface": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uri"
                },
                {
                  "type": "null"
                }
              ]
            },
            "github": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uri"
                },
                {
                  "type": "null"
                }
              ]
            },
            "paper": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uri"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "api-docs",
                  "github",
                  "gov",
                  "huggingface",
                  "model-card",
                  "official-blog",
                  "official-docs",
                  "official-website",
                  "paper",
                  "press",
                  "reference",
                  "submission"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "last_verified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "verified",
            "official-source",
            "community-reviewed",
            "submitted",
            "needs-review",
            "outdated",
            "disputed",
            "archived"
          ]
        }
      },
      "required": [
        "name",
        "organization_id",
        "status",
        "availability",
        "license",
        "sources",
        "last_verified",
        "verification_status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}