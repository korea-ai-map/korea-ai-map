{
  "$ref": "#/definitions/papers",
  "definitions": {
    "papers": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "authors_org": {
          "type": "string"
        },
        "venue": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "arxiv_id": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "doi": {
          "type": "string"
        },
        "abstract_ko": {
          "type": "string"
        },
        "related_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "last_verified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "verified",
            "official-source",
            "community-reviewed",
            "submitted",
            "needs-review",
            "outdated",
            "disputed",
            "archived"
          ]
        }
      },
      "required": [
        "title",
        "url",
        "sources",
        "last_verified",
        "verification_status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}