{
  "$ref": "#/definitions/benchmarks",
  "definitions": {
    "benchmarks": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "organization_id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "korean-understanding",
            "math-reasoning",
            "safety",
            "bias",
            "hallucination",
            "multimodal",
            "coding",
            "domain-specific"
          ]
        },
        "description_ko": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "api-docs",
                  "github",
                  "gov",
                  "huggingface",
                  "model-card",
                  "official-blog",
                  "official-docs",
                  "official-website",
                  "paper",
                  "press",
                  "reference",
                  "submission"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "last_verified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "verified",
            "official-source",
            "community-reviewed",
            "submitted",
            "needs-review",
            "outdated",
            "disputed",
            "archived"
          ]
        }
      },
      "required": [
        "name",
        "category",
        "sources",
        "last_verified",
        "verification_status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}